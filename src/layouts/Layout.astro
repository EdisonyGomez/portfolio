---
import "@fontsource-variable/nunito-sans"
import Header from '../components/Header.astro';
import Analytics from '@vercel/analytics/astro'
interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="theme-color" content="#080c14"/>
    <meta name="description" content="Portfolio de Yesid Gomez — Software Developer con 4 años de experiencia en backend, frontend, DevOps y automatizaciones. NestJS, Angular, Oracle, Azure." />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>

  <body>
    <div class="bg-grid" aria-hidden="true"></div>
    <div class="bg-glow-top" aria-hidden="true"></div>
    <div class="bg-glow-bottom" aria-hidden="true"></div>
    <Header />
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg:          #080c14;
    --surface:     #0f1623;
    --surface-2:   #161d2e;
    --border:      rgba(255, 255, 255, 0.07);
    --border-h:    rgba(255, 255, 255, 0.14);
    --accent:      #6366f1;
    --accent-2:    #818cf8;
    --accent-glow: rgba(99, 102, 241, 0.35);
    --cyan:        #06b6d4;
    --cyan-glow:   rgba(6, 182, 212, 0.25);
    --gold:        #f59e0b;
    --gold-glow:   rgba(245, 158, 11, 0.2);
    --text:        #e2e8f0;
    --text-muted:  #64748b;
    --text-soft:   #94a3b8;
    --radius:      14px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    font-family: 'Nunito Sans Variable', system-ui, sans-serif;
    background-color: var(--bg);
    color: var(--text);
    scrollbar-color: var(--accent) var(--surface);
    scrollbar-width: thin;
    scroll-behavior: smooth;
  }

  body {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100dvh;
    min-width: 100%;
    position: relative;
    overflow-x: hidden;
  }

  /* ── Background layers ── */
  .bg-grid {
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(99, 102, 241, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(99, 102, 241, 0.04) 1px, transparent 1px);
    background-size: 56px 56px;
    pointer-events: none;
    z-index: 0;
  }

  .bg-glow-top {
    position: fixed;
    top: -30%;
    left: 50%;
    transform: translateX(-50%);
    width: 900px;
    height: 900px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.13) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  .bg-glow-bottom {
    position: fixed;
    bottom: -20%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(6, 182, 212, 0.08) 0%, transparent 65%);
    pointer-events: none;
    z-index: 0;
  }

  main {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 900px;
    padding: 0 1rem;
  }

  /* ── Morphing avatar blob ── */
  .shape {
    background: linear-gradient(135deg, var(--accent) 0%, var(--cyan) 100%);
    animation: morph 8s ease-in-out infinite;
    border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
    width: clamp(200px, 42vw, 260px);
    aspect-ratio: 1 / 1;
    padding: 4px;
    z-index: 5;
    box-shadow:
      0 0 40px var(--accent-glow),
      0 0 80px var(--cyan-glow),
      inset 0 1px 0 rgba(255,255,255,0.15);
    transition: border-radius 1s ease-in-out;
  }

  .shape img,
  .shape .avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    border-radius: inherit;
    background: linear-gradient(160deg, #f1f5f9 0%, #cbd5e1 100%);
  }

  @keyframes morph {
    0%   { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
    50%  { border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%; }
    100% { border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%; }
  }

  /* ── Glass card base ── */
  .glass {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-radius: var(--radius);
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .glass:hover {
    border-color: var(--border-h);
    box-shadow: 0 8px 32px rgba(0,0,0,0.3);
  }

  /* ── Tech chip ── */
  .tech-chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    padding: 3px 8px;
    border-radius: 20px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.04);
    color: var(--text-soft);
    white-space: nowrap;
  }

  /* ── 3D card tilt ── */
  .tilt-card {
    transform-style: preserve-3d;
    transition: transform 0.12s ease, box-shadow 0.12s ease;
    will-change: transform;
  }

  /* ── Section headings ── */
  .section-title {
    font-size: 1.875rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(135deg, var(--text) 0%, var(--text-soft) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1.5rem;
  }

  .section-title svg {
    -webkit-text-fill-color: initial;
    flex-shrink: 0;
  }

  /* ── Gradient text accent ── */
  .text-gradient {
    background: linear-gradient(135deg, var(--accent-2) 0%, var(--cyan) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* ── Floating animation ── */
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }

  .float { animation: float 5s ease-in-out infinite; }

  /* ── Pulse dot (current job) ── */
  @keyframes pulse-ring {
    0%   { transform: scale(1); opacity: 0.8; }
    100% { transform: scale(2.2); opacity: 0; }
  }

  /* ── A-frame img fix ── */
  .img-aframe { width: 83px; margin: 0; padding: 0; }
</style>
